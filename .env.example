# Copy this file to .env and fill in your local values.
# dotenv-rails loads .env automatically in development and test.

# Concat (reg.offkaiexpo.com) OAuth2 credentials.
CONCAT_CLIENT_ID=
CONCAT_CLIENT_SECRET=

# Cloudflare R2 (Active Storage in production). Leave blank locally to use disk storage.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET=
