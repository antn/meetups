<% content_for :title, "My schedule · OffKai Expo" %>

<div class="mb-8">
  <h1 class="text-2xl font-bold tracking-tight text-gray-900 sm:text-3xl">My schedule</h1>
  <p class="mt-1 text-gray-500">Meetups you've said you're going to or are hosting.</p>
</div>

<% if @event && @has_meetups %>
  <%= render "meetups/tag_filter", tags: @tags, selected: @selected_tags, path: :my_schedule_path %>
  <%= render ScheduleComponent.new(event: @event, viewer: current_user, meetups: @meetups, show_open_slots: false, collapse_empty: true, selected_day: params[:day]) %>
<% else %>
  <div class="rounded-2xl border border-dashed border-gray-200 px-6 py-16 text-center">
    <%= heroicon "calendar-days", class: "mx-auto h-10 w-10 text-gray-300" %>
    <p class="mt-3 text-sm text-gray-500">Nothing here yet — tap <span class="font-semibold text-brand-purple">I'm going!</span> on a meetup to add it.</p>
    <%= link_to "Browse the schedule", root_path, class: "mt-5 inline-flex cursor-pointer items-center gap-1.5 rounded-full bg-brand-purple px-5 py-2 text-sm font-semibold text-white no-underline shadow-sm transition hover:bg-brand-purple/90" %>
  </div>
<% end %>
