<%# Link showing page number
  - available local variables
    page:          a page object for "this" page
    url:           url to this page
    current_page:  a page object for the currently displayed page
    total_pages:   total number of pages
    per_page:      number of items to fetch per page
    remote:        data-remote
-%>
<% if page.current? %>
  <span aria-current="page" class="inline-flex min-w-[2rem] items-center justify-center rounded-full bg-brand-purple px-3 py-1.5 font-semibold text-white">
    <%= page %>
  </span>
<% else %>
  <%= link_to page, url, remote: remote, rel: page.rel,
        class: "inline-flex min-w-[2rem] items-center justify-center rounded-full px-3 py-1.5 font-medium text-gray-600 no-underline transition hover:bg-gray-100" %>
<% end %>
