<% content_for :title, "Meetup schedule · OffKai Expo" %>

<div class="mb-8 flex flex-wrap items-start justify-between gap-4">
  <h1 class="text-2xl font-bold tracking-tight text-gray-900 sm:text-3xl">Meetup schedule</h1>
  <% if @event&.accepting_meetups? %>
    <% create_button_classes = "inline-flex items-center gap-1.5 rounded-full bg-brand-purple px-5 py-2.5 text-sm font-semibold text-white no-underline shadow-sm transition hover:bg-brand-purple/90" %>
    <% if signed_in? %>
      <%= link_to new_meetup_path, data: { day_link: true }, class: create_button_classes do %>
        <%= heroicon "plus", variant: "mini", class: "h-4 w-4" %>
        Create a meetup
      <% end %>
    <% else %>
      <%# Signed-out visitors get the shared sign-in modal instead of a redirect
          (same treatment as clicking an open slot). %>
      <sign-in-trigger class="contents">
        <button type="button" class="cursor-pointer <%= create_button_classes %>">
          <%= heroicon "plus", variant: "mini", class: "h-4 w-4" %>
          Create a meetup
        </button>
      </sign-in-trigger>
    <% end %>
  <% end %>
</div>

<% if @event %>
  <%= render "meetups/tag_filter", tags: @tags, selected: @selected_tags, path: :root_path %>
  <%= render ScheduleComponent.new(event: @event, viewer: current_user, meetups: @meetups, selected_day: params[:day]) %>
<% else %>
  <div class="rounded-2xl border border-dashed border-gray-300 bg-white p-12 text-center">
    <%= heroicon "calendar", class: "mx-auto h-10 w-10 text-gray-300" %>
    <h2 class="mt-3 text-lg font-semibold text-gray-900">No event scheduled</h2>
    <p class="mx-auto mt-1 max-w-md text-sm text-gray-500">
      There's no event currently accepting meetups. Check back soon!
    </p>
  </div>
<% end %>
