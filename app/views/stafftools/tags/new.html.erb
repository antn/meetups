<% content_for :title, "Add tag · Stafftools" %>

<%= link_to stafftools_tags_path, class: "inline-flex items-center gap-1 text-sm font-medium text-gray-500 no-underline transition hover:text-brand-purple" do %>
  <%= heroicon "arrow-left", variant: "mini", class: "h-4 w-4" %>
  Tags
<% end %>

<h1 class="mt-4 text-2xl font-bold tracking-tight text-gray-900">Add tag</h1>

<div class="mt-6 max-w-xl rounded-2xl border border-gray-100 bg-white p-6 shadow-sm">
  <%= render "form", tag: @tag, url: stafftools_tags_path, method: :post, submit_label: "Add tag" %>
</div>
