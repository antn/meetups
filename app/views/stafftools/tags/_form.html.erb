<%= form_with model: tag, url: url, method: method, class: "space-y-5" do |f| %>
  <% if tag.errors.any? %>
    <div class="rounded-xl bg-red-50 px-4 py-3 text-sm text-red-800 ring-1 ring-red-200">
      <p class="font-semibold">Please fix the following:</p>
      <ul class="mt-1 list-disc pl-5">
        <% tag.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_field :name, class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-brand-purple focus:ring-brand-purple" %>
  </div>

  <div>
    <span class="block text-sm font-medium text-gray-700">Color</span>
    <div class="mt-2 flex flex-wrap gap-3">
      <% Tag::COLORS.each do |color| %>
        <label class="cursor-pointer">
          <%= f.radio_button :color, color, class: "peer sr-only" %>
          <span class="block h-9 w-9 rounded-full ring-2 ring-transparent ring-offset-2 transition peer-checked:ring-gray-900 hover:ring-gray-300 <%= tag_swatch_class(color) %>"
                title="<%= color.capitalize %>"></span>
        </label>
      <% end %>
    </div>
  </div>

  <div class="flex items-center gap-3">
    <%= f.submit submit_label, class: "cursor-pointer rounded-full bg-brand-purple px-5 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-brand-purple/90" %>
    <%= link_to "Cancel", stafftools_tags_path, class: "text-sm font-medium text-gray-500 no-underline hover:text-gray-700" %>
  </div>
<% end %>
