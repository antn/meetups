<% content_for :title, "Tags · Stafftools" %>

<div class="flex items-center justify-between">
  <div>
    <h1 class="text-2xl font-bold tracking-tight text-gray-900">Tags</h1>
    <p class="mt-1 text-sm text-gray-500">Topics hosts can label their meetups with.</p>
  </div>
  <%= link_to new_stafftools_tag_path, class: "inline-flex items-center gap-1.5 rounded-full bg-brand-purple px-4 py-2 text-sm font-semibold text-white no-underline shadow-sm transition hover:bg-brand-purple/90" do %>
    <%= heroicon "plus", variant: "mini", class: "h-4 w-4" %>
    Add tag
  <% end %>
</div>

<% if @tags.any? %>
  <div class="mt-6 overflow-hidden rounded-2xl border border-gray-100 bg-white shadow-sm">
    <table class="min-w-full divide-y divide-gray-100 text-sm">
      <thead class="bg-gray-50 text-left text-xs font-semibold uppercase tracking-wide text-gray-400">
        <tr>
          <th class="px-6 py-3">Name</th>
          <th class="px-6 py-3">Meetups</th>
          <th class="px-6 py-3 text-right">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @tags.each do |tag| %>
          <tr>
            <td class="px-6 py-4">
              <span class="inline-flex rounded-full px-2.5 py-0.5 text-xs font-medium <%= tag_chip_classes(tag.color) %>"><%= tag.name %></span>
            </td>
            <td class="px-6 py-4 text-gray-600"><%= tag.meetups.size %></td>
            <td class="px-6 py-4">
              <div class="flex items-center justify-end gap-3">
                <%= link_to "Edit", edit_stafftools_tag_path(tag), class: "font-medium text-brand-purple no-underline hover:underline" %>
                <%= button_to "Remove", stafftools_tag_path(tag), method: :delete,
                      form: { data: { turbo_confirm: "Remove this tag? It will be removed from any meetups using it." } },
                      class: "cursor-pointer font-medium text-red-600 hover:underline" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="mt-6 rounded-2xl border border-dashed border-gray-300 bg-white p-10 text-center">
    <p class="text-sm text-gray-500">No tags yet. Add a few so hosts can categorize their meetups.</p>
  </div>
<% end %>
