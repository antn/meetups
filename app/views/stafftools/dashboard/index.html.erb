<% content_for :title, "Stafftools · Meetups" %>

<% if current_event.nil? %>
  <div class="rounded-2xl border border-dashed border-gray-300 bg-white p-10 text-center">
    <%= heroicon "calendar", class: "mx-auto h-10 w-10 text-gray-300" %>
    <h1 class="mt-3 text-lg font-semibold text-gray-900">No active event</h1>
    <p class="mx-auto mt-1 max-w-md text-sm text-gray-500">
      There's no event currently accepting meetups. Create one and set it active to get started.
    </p>
    <%= link_to "Manage events", stafftools_events_path, class: "mt-4 inline-flex items-center gap-1.5 rounded-full bg-brand-purple px-4 py-2 text-sm font-semibold text-white no-underline shadow-sm transition hover:bg-brand-purple/90" %>
  </div>
<% else %>
  <h1 class="text-2xl font-bold tracking-tight text-gray-900">Dashboard</h1>
  <p class="mt-1 text-sm text-gray-500">An overview of <span class="font-medium text-gray-700"><%= current_event.name %></span>.</p>

  <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    <%= link_to stafftools_meetups_path, class: "block rounded-2xl border border-gray-100 bg-white p-5 no-underline shadow-sm transition hover:border-brand-purple/40 hover:shadow" do %>
      <div class="flex items-center justify-between">
        <span class="text-sm font-medium text-gray-500">Pending meetups</span>
        <%= heroicon "clock", variant: "mini", class: "h-5 w-5 text-amber-500" %>
      </div>
      <p class="mt-2 text-3xl font-bold text-gray-900"><%= @pending_count %></p>
      <p class="mt-1 text-xs font-medium text-brand-purple">Review &rarr;</p>
    <% end %>

    <%= link_to stafftools_scheduling_days_path, class: "block rounded-2xl border border-gray-100 bg-white p-5 no-underline shadow-sm transition hover:border-brand-purple/40 hover:shadow" do %>
      <div class="flex items-center justify-between">
        <span class="text-sm font-medium text-gray-500">Meetup days</span>
        <%= heroicon "calendar-days", variant: "mini", class: "h-5 w-5 text-brand-pink" %>
      </div>
      <p class="mt-2 text-3xl font-bold text-gray-900"><%= @scheduling_day_count %></p>
      <p class="mt-1 text-xs font-medium text-brand-purple">Manage &rarr;</p>
    <% end %>

    <%= link_to stafftools_locations_path, class: "block rounded-2xl border border-gray-100 bg-white p-5 no-underline shadow-sm transition hover:border-brand-purple/40 hover:shadow" do %>
      <div class="flex items-center justify-between">
        <span class="text-sm font-medium text-gray-500">Locations</span>
        <%= heroicon "map-pin", variant: "mini", class: "h-5 w-5 text-brand-pink" %>
      </div>
      <p class="mt-2 text-3xl font-bold text-gray-900"><%= @location_count %></p>
      <p class="mt-1 text-xs font-medium text-brand-purple">Manage &rarr;</p>
    <% end %>

    <%= link_to stafftools_tags_path, class: "block rounded-2xl border border-gray-100 bg-white p-5 no-underline shadow-sm transition hover:border-brand-purple/40 hover:shadow" do %>
      <div class="flex items-center justify-between">
        <span class="text-sm font-medium text-gray-500">Tags</span>
        <%= heroicon "tag", variant: "mini", class: "h-5 w-5 text-brand-pink" %>
      </div>
      <p class="mt-2 text-3xl font-bold text-gray-900"><%= @tag_count %></p>
      <p class="mt-1 text-xs font-medium text-brand-purple">Manage &rarr;</p>
    <% end %>
  </div>
<% end %>
