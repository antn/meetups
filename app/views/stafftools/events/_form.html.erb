<%= form_with model: event, url: url, method: method, class: "space-y-5" do |f| %>
  <% if event.errors.any? %>
    <div class="rounded-xl bg-red-50 px-4 py-3 text-sm text-red-800 ring-1 ring-red-200">
      <p class="font-semibold">Please fix the following:</p>
      <ul class="mt-1 list-disc pl-5">
        <% event.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_field :name, class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-brand-purple focus:ring-brand-purple" %>
  </div>

  <div>
    <%= f.label :time_zone, class: "block text-sm font-medium text-gray-700" %>
    <%= f.time_zone_select :time_zone, nil, { include_blank: "Select a time zone" },
          class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-brand-purple focus:ring-brand-purple" %>
    <p class="mt-1 text-xs text-gray-400">Used to interpret scheduling days and meetup times.</p>
  </div>

  <div class="flex items-center gap-3">
    <%= f.submit submit_label, class: "cursor-pointer rounded-full bg-brand-purple px-5 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-brand-purple/90" %>
    <%= link_to "Cancel", stafftools_events_path, class: "text-sm font-medium text-gray-500 no-underline hover:text-gray-700" %>
  </div>
<% end %>
