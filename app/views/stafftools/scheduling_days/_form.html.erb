<%= form_with model: scheduling_day, url: url, method: method, class: "space-y-5" do |f| %>
  <% if scheduling_day.errors.any? %>
    <div class="rounded-xl bg-red-50 px-4 py-3 text-sm text-red-800 ring-1 ring-red-200">
      <p class="font-semibold">Please fix the following:</p>
      <ul class="mt-1 list-disc pl-5">
        <% scheduling_day.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :date, class: "block text-sm font-medium text-gray-700" %>
    <%= f.date_field :date, class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-brand-purple focus:ring-brand-purple" %>
  </div>

  <div class="grid gap-4 sm:grid-cols-2">
    <div>
      <%= f.label :start_time, "Opens at", class: "block text-sm font-medium text-gray-700" %>
      <%= f.time_field :start_time, step: 3600, class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-brand-purple focus:ring-brand-purple" %>
    </div>
    <div>
      <%= f.label :end_time, "Closes at", class: "block text-sm font-medium text-gray-700" %>
      <%= f.time_field :end_time, step: 3600, class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-brand-purple focus:ring-brand-purple" %>
    </div>
  </div>
  <p class="text-xs text-gray-400">Times must land on the hour. The last meetup begins one hour before closing.</p>

  <div class="flex items-center gap-3">
    <%= f.submit submit_label, class: "cursor-pointer rounded-full bg-brand-purple px-5 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-brand-purple/90" %>
    <%= link_to "Cancel", stafftools_scheduling_days_path, class: "text-sm font-medium text-gray-500 no-underline hover:text-gray-700" %>
  </div>
<% end %>
