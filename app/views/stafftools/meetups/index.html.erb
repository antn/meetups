<% content_for :title, "Meetups · Stafftools" %>

<div>
  <h1 class="text-2xl font-bold tracking-tight text-gray-900">Meetups</h1>
  <p class="mt-1 text-sm text-gray-500">Every submission for this event. Approving publishes a meetup; rejecting frees the slot.</p>
</div>

<staff-review data-action="submit:staff-review#submit">
<div class="mt-6 flex flex-wrap gap-2">
  <% Stafftools::MeetupsController::STATUSES.each do |status| %>
    <% selected = status == @status %>
    <% state = selected ? "bg-brand-purple text-white" : "bg-white text-gray-600 ring-1 ring-gray-200 hover:bg-gray-50" %>
    <%= link_to stafftools_meetups_path(status: status), class: "inline-flex items-center gap-1.5 rounded-full px-3.5 py-1.5 text-sm font-medium no-underline transition #{state}" do %>
      <%= status.titleize %>
      <span data-targets="staff-review.counts" data-status="<%= status %>" class="rounded-full px-1.5 text-xs <%= selected ? "bg-white/20" : "bg-gray-100" %>"><%= @status_counts[status] %></span>
    <% end %>
  <% end %>
</div>

<% if @meetups.any? %>
  <div class="mt-6 space-y-4">
    <% @meetups.each do |meetup| %>
      <article id="meetup_<%= meetup.id %>" data-review-card class="overflow-hidden rounded-2xl border border-gray-100 bg-white shadow-sm">
        <div class="flex flex-col gap-6 p-6 sm:flex-row sm:items-start sm:justify-between">
          <div class="min-w-0">
            <div class="flex items-center gap-2">
              <span class="inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 text-xs font-semibold ring-1 <%= meetup_status_badge_classes(meetup.status) %>">
                <%= meetup.status.titleize %>
              </span>
              <%= link_to "Details", stafftools_meetup_path(meetup), class: "text-xs font-medium text-brand-purple no-underline hover:underline" %>
              <% if meetup.editable_by?(current_user) %>
                <%= link_to "Edit", edit_stafftools_meetup_path(meetup), class: "text-xs font-medium text-gray-500 no-underline hover:underline" %>
              <% end %>
            </div>

            <h2 class="mt-2 text-lg font-semibold text-gray-900"><%= meetup.title %></h2>
            <p class="text-sm text-gray-500">Hosted by
              <%= link_to meetup.user.housekeeping_url, target: "_blank", rel: "noopener", class: "inline-flex items-center gap-1 font-medium text-brand-purple no-underline hover:underline" do %>
                <%= meetup.user.login %>
                <%= heroicon "arrow-top-right-on-square", variant: "mini", class: "h-3.5 w-3.5" %>
              <% end %>
            </p>

            <dl class="mt-3 flex flex-wrap gap-x-6 gap-y-1 text-sm text-gray-600">
              <div class="flex items-center gap-1.5">
                <%= heroicon "map-pin", variant: "mini", class: "h-4 w-4 text-brand-pink" %>
                <%= meetup.location.name %>
              </div>
              <div class="flex items-center gap-1.5">
                <%= heroicon "calendar-days", variant: "mini", class: "h-4 w-4 text-brand-pink" %>
                <%= meetup.starts_at.in_time_zone(current_event.tz).strftime("%a %b %-d, %-l:%M %p") %>
                &ndash;
                <%= meetup.ends_at.in_time_zone(current_event.tz).strftime("%-l:%M %p") %>
              </div>
            </dl>

            <% if meetup.tags.any? %>
              <div class="mt-3 flex flex-wrap gap-1.5">
                <% meetup.tags.each do |tag| %>
                  <span class="rounded-full px-2.5 py-0.5 text-xs font-medium <%= tag_chip_classes(tag.color) %>"><%= tag.name %></span>
                <% end %>
              </div>
            <% end %>

            <% if meetup.description.present? %>
              <p class="mt-3 max-w-prose text-sm leading-relaxed text-gray-700"><%= meetup.description %></p>
            <% end %>

            <% if meetup.rejected? && meetup.rejection_reason.present? %>
              <p class="mt-3 max-w-prose rounded-lg bg-red-50 px-3 py-2 text-sm text-red-700 ring-1 ring-red-200">
                <span class="font-semibold">Rejected:</span> <%= meetup.rejection_reason %>
              </p>
            <% end %>
          </div>

          <% if meetup.pending? %>
            <div class="shrink-0 sm:w-64">
              <%= button_to "Approve", approve_stafftools_meetup_path(meetup), method: :patch,
                    class: "flex w-full cursor-pointer items-center justify-center gap-1.5 rounded-full bg-green-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-green-700" %>

              <%= form_with url: reject_stafftools_meetup_path(meetup), method: :patch, class: "mt-3 space-y-2" do %>
                <%= text_field_tag :rejection_reason, nil,
                      placeholder: "Reason for rejection",
                      class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-red-400 focus:ring-red-400" %>
                <%= submit_tag "Reject", class: "w-full cursor-pointer rounded-full border border-red-200 bg-white px-4 py-2 text-sm font-semibold text-red-600 transition hover:bg-red-50" %>
              <% end %>
            </div>
          <% elsif meetup.approved? %>
            <div class="shrink-0 space-y-3 sm:w-64">
              <div class="text-sm text-gray-500 sm:text-right">
                Approved
                <% if meetup.reviewed_by %>by <span class="font-medium text-gray-700"><%= meetup.reviewed_by.login %></span><% end %>
                <% if meetup.reviewed_at %>
                  <br>
                  <span class="text-xs text-gray-400"><%= meetup.reviewed_at.in_time_zone(current_event.tz).strftime("%b %-d, %-l:%M %p") %></span>
                <% end %>
              </div>

              <%= button_to "Move to pending", unapprove_stafftools_meetup_path(meetup), method: :patch,
                    form: { data: { confirm: "Move “#{meetup.title}” back to pending? It will be unpublished until re-approved." } },
                    class: "flex w-full cursor-pointer items-center justify-center rounded-full border border-gray-300 bg-white px-4 py-2 text-sm font-semibold text-gray-700 transition hover:bg-gray-50" %>

              <%= button_to "Cancel meetup", cancel_stafftools_meetup_path(meetup), method: :patch,
                    form: { data: { confirm: "Cancel “#{meetup.title}”? This unpublishes it and frees the slot." } },
                    class: "flex w-full cursor-pointer items-center justify-center rounded-full border border-gray-300 bg-white px-4 py-2 text-sm font-semibold text-gray-700 transition hover:bg-gray-50" %>

              <%= form_with url: reject_stafftools_meetup_path(meetup), method: :patch, class: "space-y-2" do %>
                <%= text_field_tag :rejection_reason, nil,
                      placeholder: "Reason for rejection",
                      class: "block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-red-400 focus:ring-red-400" %>
                <%= submit_tag "Reject", class: "w-full cursor-pointer rounded-full border border-red-200 bg-white px-4 py-2 text-sm font-semibold text-red-600 transition hover:bg-red-50" %>
              <% end %>
            </div>
          <% elsif meetup.reviewed_at.present? %>
            <div class="shrink-0 text-sm text-gray-500 sm:w-64 sm:text-right">
              <%= meetup.status.titleize %>
              <% if meetup.reviewed_by %>by <span class="font-medium text-gray-700"><%= meetup.reviewed_by.login %></span><% end %>
              <br>
              <span class="text-xs text-gray-400"><%= meetup.reviewed_at.in_time_zone(current_event.tz).strftime("%b %-d, %-l:%M %p") %></span>
            </div>
          <% end %>
        </div>
      </article>
    <% end %>
  </div>
<% else %>
  <div class="mt-6 rounded-2xl border border-dashed border-gray-300 bg-white p-10 text-center">
    <%= heroicon "inbox", class: "mx-auto h-10 w-10 text-gray-300" %>
    <p class="mt-2 text-sm text-gray-500">No <%= @status %> meetups.</p>
  </div>
<% end %>
</staff-review>
