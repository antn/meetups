<% content_for :title, "Edit location · Stafftools" %>

<%= link_to stafftools_locations_path, class: "inline-flex items-center gap-1 text-sm font-medium text-gray-500 no-underline transition hover:text-brand-purple" do %>
  <%= heroicon "arrow-left", variant: "mini", class: "h-4 w-4" %>
  Locations
<% end %>

<h1 class="mt-4 text-2xl font-bold tracking-tight text-gray-900">Edit location</h1>

<div class="mt-6 max-w-xl rounded-2xl border border-gray-100 bg-white p-6 shadow-sm">
  <%= render "form", location: @location, url: stafftools_location_path(@location), method: :patch, submit_label: "Save changes" %>
</div>
