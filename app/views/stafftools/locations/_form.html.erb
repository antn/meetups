<%= form_with model: location, url: url, method: method, class: "space-y-5" do |f| %>
  <% if location.errors.any? %>
    <div class="rounded-xl bg-red-50 px-4 py-3 text-sm text-red-800 ring-1 ring-red-200">
      <p class="font-semibold">Please fix the following:</p>
      <ul class="mt-1 list-disc pl-5">
        <% location.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_field :name, class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-brand-purple focus:ring-brand-purple" %>
  </div>

  <div>
    <%= f.label :description, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_area :description, rows: 3, class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-brand-purple focus:ring-brand-purple" %>
  </div>

  <label class="flex items-center gap-2 text-sm text-gray-700">
    <%= f.check_box :active, class: "h-4 w-4 rounded border-gray-300 text-brand-purple focus:ring-brand-purple" %>
    Available for booking
  </label>

  <div class="flex items-center gap-3">
    <%= f.submit submit_label, class: "cursor-pointer rounded-full bg-brand-purple px-5 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-brand-purple/90" %>
    <%= link_to "Cancel", stafftools_locations_path, class: "text-sm font-medium text-gray-500 no-underline hover:text-gray-700" %>
  </div>
<% end %>
