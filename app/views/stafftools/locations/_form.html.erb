<%= form_with model: location, url: url, method: method, class: "space-y-5" do |f| %>
  <% if location.errors.any? %>
    <div class="rounded-xl bg-red-50 px-4 py-3 text-sm text-red-800 ring-1 ring-red-200">
      <p class="font-semibold">Please fix the following:</p>
      <ul class="mt-1 list-disc pl-5">
        <% location.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_field :name, class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-brand-purple focus:ring-brand-purple" %>
  </div>

  <div>
    <%= f.label :description, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_area :description, rows: 3, class: "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-brand-purple focus:ring-brand-purple" %>
  </div>

  <div>
    <%= f.label :map_image, "Map image", class: "block text-sm font-medium text-gray-700" %>
    <p class="mt-0.5 text-xs text-gray-500">Shown on the meetup page. PNG, JPEG, or WebP, up to 1 MB.</p>
    <% if location.persisted? && location.map_image.attached? %>
      <%= image_tag location.map_image, class: "mt-2 h-32 w-auto rounded-lg border border-gray-200 object-cover" %>
    <% end %>
    <%= f.file_field :map_image, accept: "image/png,image/jpeg,image/webp", class: "mt-2 block w-full text-sm text-gray-700 file:mr-3 file:cursor-pointer file:rounded-full file:border-0 file:bg-brand-purple/10 file:px-4 file:py-2 file:text-sm file:font-semibold file:text-brand-purple hover:file:bg-brand-purple/20" %>
  </div>

  <label class="flex items-center gap-2 text-sm text-gray-700">
    <%= f.check_box :active, class: "h-4 w-4 rounded border-gray-300 text-brand-purple focus:ring-brand-purple" %>
    Available for booking
  </label>

  <% scheduling_days = location.event.scheduling_days.order(:date) %>
  <% if scheduling_days.any? %>
    <fieldset>
      <legend class="text-sm font-medium text-gray-700">Hourly availability</legend>
      <p class="mt-0.5 text-xs text-gray-500">Toggle an hour off to block new bookings for this location during it. Meetups already booked in a blocked hour stay scheduled.</p>
      <%# Marks the grid as submitted even when every chip is unchecked, so the
          controller can tell "all blocked" apart from "grid not rendered". %>
      <%= hidden_field_tag "location[available_hour_keys][]", "" %>
      <% blocked = location.blocked_hours.pluck(:scheduling_day_id, :hour).to_set %>
      <div class="mt-3 space-y-3">
        <% scheduling_days.each do |day| %>
          <div>
            <p class="text-xs font-semibold text-gray-500"><%= day.date.strftime("%A, %b %-d") %></p>
            <div class="mt-1.5 flex flex-wrap gap-2">
              <% day.valid_start_times.each do |start_time| %>
                <label class="cursor-pointer">
                  <%= check_box_tag "location[available_hour_keys][]", "#{day.id}:#{start_time.hour}",
                        !blocked.include?([ day.id, start_time.hour ]),
                        id: "location_hour_#{day.id}_#{start_time.hour}",
                        class: "peer sr-only" %>
                  <span class="inline-flex rounded-full bg-gray-100 px-2.5 py-1 text-xs font-medium text-gray-400 line-through ring-1 ring-gray-200 transition peer-checked:bg-brand-purple/10 peer-checked:text-brand-purple peer-checked:no-underline peer-checked:ring-brand-purple/40"><%= start_time.strftime("%-l %p") %></span>
                </label>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
      <% blocked_meetups = location.persisted? ? location.meetups_in_blocked_hours : [] %>
      <% if blocked_meetups.any? %>
        <p class="mt-3 rounded-lg bg-amber-50 px-3 py-2 text-xs text-amber-800 ring-1 ring-amber-200">
          <%= pluralize(blocked_meetups.size, "existing meetup") %> <%= blocked_meetups.size == 1 ? "falls" : "fall" %> in a blocked hour and will stay scheduled.
        </p>
      <% end %>
    </fieldset>
  <% end %>

  <div class="flex items-center gap-3">
    <%= f.submit submit_label, class: "cursor-pointer rounded-full bg-brand-purple px-5 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-brand-purple/90" %>
    <%= link_to "Cancel", stafftools_locations_path, class: "text-sm font-medium text-gray-500 no-underline hover:text-gray-700" %>
  </div>
<% end %>
